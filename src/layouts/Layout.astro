---
// ─── Base document layout ───
// Server-rendered <head> with the full design-system stylesheet, OpenGraph and
// Twitter Card metadata for social-media parsers, and the ambient-music markup +
// control script (extracted out of the original inline <script>). The page body
// is supplied via <slot/> (index.astro renders the React app island into it).
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Sentinel — Build your own decentralized VPN.',
  description = 'Sentinel is a Layer-1 decentralized bandwidth network. Bring your protocol, your client, your distribution — we handle the network.',
} = Astro.props;

// Canonical/social URL. Resolves against Astro.site when set; falls back to the
// production homepage so OG tags carry an absolute URL even in static preview.
const SITE = 'https://sentinel.co/';
const canonical = new URL(Astro.url.pathname, Astro.site ?? SITE).toString();
const ogImage = new URL('/assets/img/og-cover.png', Astro.site ?? SITE).toString();
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- OpenGraph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Sentinel" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Sentinel — decentralized Layer-1 bandwidth network" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@sentinelp2p" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <meta name="theme-color" content="#0156FC" />
  </head>
  <body>
    <a class="sn-skip" href="#main">Skip to content</a>

    <slot />

    <!-- Ambient music: OFF by default, pure intent toggle. -->
    <div id="sn-music">
      <span id="sn-music-label" aria-hidden="true">Sound &middot; off</span>
      <button id="sn-music-btn" type="button" aria-pressed="false" aria-label="Unmute ambient music" title="Unmute ambient music">
        <svg class="sn-music-play" width="16" height="14" viewBox="0 0 16 14" fill="none" aria-hidden="true"><path d="M8.2 1.1a.7.7 0 0 1 1.1.6v10.6a.7.7 0 0 1-1.1.6L4.6 10H2.4A1.4 1.4 0 0 1 1 8.6V5.4C1 4.6 1.6 4 2.4 4h2.2l3.6-2.9z" fill="currentColor"/><path d="M11.2 4.8 14.8 9.2M14.8 4.8 11.2 9.2" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
        <span class="sn-music-bars" aria-hidden="true"><i></i><i></i><i></i></span>
      </button>
      <audio id="sn-music-audio" src="/assets/media/ambient-music.mp3" loop preload="auto"></audio>
    </div>
    <script is:inline src="/scripts/music.js"></script>
  </body>
</html>
