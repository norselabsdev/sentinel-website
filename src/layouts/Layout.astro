---
// ─── Base document layout ───
// Server-rendered <head> with the full design-system stylesheet, OpenGraph and
// Twitter Card metadata for social-media parsers, and the ambient-music markup +
// control script (extracted out of the original inline <script>). The page body
// is supplied via <slot/> (index.astro renders the React app island into it).
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

// i18n: the middleware resolves the locale per request and stashes the active
// locale, text direction, and translated head strings on Astro.locals. Props
// can still override title/description for one-off pages.
const i18n = Astro.locals.i18n;
const {
  title = i18n.title,
  description = i18n.description,
} = Astro.props;
const { locale, dir, ogImageAlt } = i18n;

// Server's coarse UA-based mobile guess (middleware). Seeded onto the page so the
// island hydrates with the same isMobile the server rendered with — no flash.
const isMobile = Astro.locals.isMobile ?? false;

// Canonical/social URL. Resolves against Astro.site when set; falls back to the
// production homepage so OG tags carry an absolute URL even in static preview.
const SITE = 'https://sentinel.co/';
const canonical = new URL(Astro.url.pathname, Astro.site ?? SITE).toString();
const ogImage = new URL('/assets/img/og-cover.png', Astro.site ?? SITE).toString();

// og:locale wants an underscore-joined territory form (en_US). Map each supported
// UI locale to a representative region; fall back to the bare language code.
const OG_LOCALES: Record<string, string> = {
  en: 'en_US', es: 'es_ES', zh: 'zh_CN', ru: 'ru_RU', de: 'de_DE',
  fr: 'fr_FR', ar: 'ar_AR', fa: 'fa_IR', pt: 'pt_BR',
};
const ogLocale = OG_LOCALES[locale] ?? locale;
---

<!DOCTYPE html>
<html lang={locale} dir={dir}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <link rel="canonical" href={canonical} />

    <!-- OpenGraph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Sentinel" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@sentinelp2p" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <meta name="theme-color" content="#0156FC" />

    <!-- Preload the latin Funnel Display woff2 (the headline/CTA face, U+0000-00FF).
         Without this the hero CTAs first paint in the system-ui fallback, then
         visibly resize when Funnel Display swaps in on mobile refresh (FOUC flash).
         Preloading makes the real font available at first paint. Keep this URL in
         sync with the /* latin */ @font-face src in global.css. -->
    <link
      rel="preload"
      href="/assets/fonts/d3835081-8789-4264-9ac0-d8d2f7d8b482.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <!-- Critical inline CSS — applied on first paint, BEFORE the external
         global.css <link> loads. Without this the un-styled skip link flashes
         visibly in the top-left and the dark background pops in late (FOUC).
         These rules duplicate the canonical ones in global.css; keep them in
         sync if the skip link / base background design changes. -->
    <style is:inline>
      html, body { margin:0; background:#0b0c10; color:#eaeaea; }
      /* Pre-hide the skip link until it is focused. Its full styling lives only
         in the external global.css, so without this it paints visibly in the
         top-left until that stylesheet loads. Mirrors global.css .sn-skip. */
      .sn-skip { position:absolute; left:8px; top:8px; transform:translateY(-200%); }
      .sn-skip:focus { transform:translateY(0); }
    </style>

    <!-- Seed the active locale before the React island hydrates, so the client's
         globals bootstrap (lib/globals.ts) re-applies the same locale the server
         rendered with — keeping SSR markup and hydration in sync. -->
    <script is:inline define:vars={{ locale, isMobile }}>
      window.__locale = locale;
      window.__isMobile = isMobile;
    </script>
  </head>
  <body>
    <a class="sn-skip" href="#main">Skip to content</a>

    <slot />

    <!-- Ambient music: OFF by default, pure intent toggle. -->
    <div id="sn-music">
      <span id="sn-music-label" aria-hidden="true">Sound &middot; off</span>
      <button id="sn-music-btn" type="button" aria-pressed="false" aria-label="Unmute ambient music" title="Unmute ambient music">
        <svg class="sn-music-play" width="16" height="14" viewBox="0 0 16 14" fill="none" aria-hidden="true"><path d="M8.2 1.1a.7.7 0 0 1 1.1.6v10.6a.7.7 0 0 1-1.1.6L4.6 10H2.4A1.4 1.4 0 0 1 1 8.6V5.4C1 4.6 1.6 4 2.4 4h2.2l3.6-2.9z" fill="currentColor"/><path d="M11.2 4.8 14.8 9.2M14.8 4.8 11.2 9.2" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
        <span class="sn-music-bars" aria-hidden="true"><i></i><i></i><i></i></span>
      </button>
      <audio id="sn-music-audio" src="/assets/media/ambient-music.mp3" loop preload="auto"></audio>
    </div>
    <script is:inline src="/scripts/music.js"></script>
  </body>
</html>
